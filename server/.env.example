# Database — локально TCP (MYSQL_SOCKET пустой):
# DATABASE_URL: спецсимволы в пароле в URL кодируй: ( → %28 ) → %29 @ → %40 : → %3A
DATABASE_URL=mysql://root:password@localhost:3306/dobrunia_auth
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=dobrunia_auth
# MYSQL_SOCKET=

# С сокетом MySQL (панель хостинга): задай MYSQL_SOCKET и DB_*; DATABASE_URL можно оставить с теми же данными (пароль в URI — encoded).
# MYSQL_SOCKET=/run/mysqld/mysqld.sock

# Панель может задавать вместо DB_*: DBUSER, DBPASS, DBNAME, DBHOST, DB_CONNECTION_STRING —
# они автоматически маппятся, если DB_USER / DATABASE_URL и т.д. не заданы.
# APP_PORT / APP_IP → PORT / HOST, если последние пустые.
# FRONTEND_URL → AUTH_WEB_PUBLIC_URL (SPA на другом домене — иначе браузер режет CORS).

# JWT (в production — свои длинные случайные строки, ≥32 символов)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
ACCESS_TOKEN_EXPIRES_SEC=3600
REFRESH_TOKEN_EXPIRES_DAYS=30

# Публичный URL SPA (https в production, без слэша). Origin добавляется в CORS — обязателен, если SPA на другом домене, чем API.
AUTH_WEB_PUBLIC_URL=http://localhost:5173
# Алиас с панели: FRONTEND_URL → то же самое.

# Локально: явно перечисли origin (дефолт в схеме пустой — без этого в production не будет CORS для guru и т.д.).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# CORS_REFLECT_ORIGIN=false

# Сервер
PORT=3000
HOST=localhost

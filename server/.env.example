# Database - MySQL 8
# If not provided, defaults: localhost:3306, root/password, db: dobrunia_auth
DATABASE_URL=mysql://root:password@localhost:3306/dobrunia_auth
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=dobrunia_auth

# JWT Secrets
# In production, use long random strings (min 32 characters)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
# Access JWT TTL, секунды (дефолт в коде: см. constants/jwt.constants.ts)
ACCESS_TOKEN_EXPIRES_SEC=3600
REFRESH_TOKEN_EXPIRES_DAYS=30

# Публичный URL SPA auth-web (без слэша). OAuth-bridge + его origin автоматически попадает в CORS.
AUTH_WEB_PUBLIC_URL=http://localhost:5173

# CORS: дополнительные origin (через запятую). Origin из AUTH_WEB_PUBLIC_URL добавляется автоматически.
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Любой домен SPA (магазины, партнёры): CORS_REFLECT_ORIGIN=true
# CORS_REFLECT_ORIGIN=false
# В production при reflect по умолчанию только https (+ localhost http). Явно: CORS_REFLECT_HTTPS_ONLY=false
# CORS_REFLECT_HTTPS_ONLY=

# Server
PORT=3000
HOST=localhost
